# Main function
function main
    # Parse arguments
    if test (count $argv) -eq 0
        show_help
        return 1
    end

    switch $argv[1]
        case --help -h
            show_help
            return 0
        case --list -l
            list_themes
            return 0
        case --current -c
            show_current
            return $status
        case '--*'
            log_error "Unknown option: $argv[1]"
            show_help
            return 1
    end

    set -g THEME_NAME $argv[1]
    set -l theme_file "$THEMES_DIR/$THEME_NAME.conf"

    if not test -f $theme_file
        log_error "Theme not found: $THEME_NAME"
        echo "Available themes:"
        list_themes
        return 1
    end

    echo ""
    log_info "Applying theme: $THEME_NAME"
    echo ""

    # Load theme colors
    if not load_theme $theme_file
        return 1
    end

    # Apply to all applications
    apply_hyprland
    apply_foot
    apply_mako
    apply_waybar
    apply_starship
    apply_fish
    apply_nvim
    apply_fuzzel
    apply_rofi
    apply_tmux
    apply_gtk
    apply_wlogout
    apply_hyprlock

    # Save current theme
    echo $THEME_NAME > $CURRENT_THEME_FILE

    echo ""
    log_success "Theme '$THEME_NAME' applied successfully!"
    echo ""
    echo "Some changes may require:"
    echo "  - Restart your terminal for full effect"
    echo "  - Run 'source ~/.config/fish/conf.d/theme.fish' for fish colors"
    echo "  - Restart nvim for editor colors"
end

main $argv
