    echo "set -g fish_pager_color_progress \"#"(get_color light)"\"" >> $fish_theme

    log_success "Fish theme: $fish_theme"

    # Source the theme immediately if we're in fish
    source $fish_theme 2>/dev/null
    log_success "Fish colors applied"
end

# Update Neovim colorscheme - creates a full colorscheme at lua/themes/current.lua
function apply_nvim
    set -l nvim_theme "$HOME/.config/nvim/lua/themes/current.lua"

    log_info "Applying to Neovim..."

    mkdir -p (dirname $nvim_theme)

    # Generate a complete colorscheme file
    echo "-- Theme: $THEME_NAME - Auto-generated by theme-apply.fish" > $nvim_theme
    echo "-- Usage: require('themes.current').setup()" >> $nvim_theme
    echo "" >> $nvim_theme
    echo "local M = {}" >> $nvim_theme
    echo "" >> $nvim_theme
    echo "local colors = {" >> $nvim_theme
    echo "    bg = \"#"(get_color bg)"\"," >> $nvim_theme
    echo "    fg = \"#"(get_color fg)"\"," >> $nvim_theme
    echo "    dark = \"#"(get_color dark)"\"," >> $nvim_theme
    echo "    medium = \"#"(get_color medium)"\"," >> $nvim_theme
    echo "    light = \"#"(get_color light)"\"," >> $nvim_theme
    echo "    accent = \"#"(get_color accent)"\"," >> $nvim_theme
    echo "    surface = \"#"(get_color surface)"\"," >> $nvim_theme
    echo "    error = \"#"(get_color error)"\"," >> $nvim_theme
    echo "    warning = \"#"(get_color warning)"\"," >> $nvim_theme
    echo "    success = \"#"(get_color success)"\"," >> $nvim_theme
    echo "    black = \"#"(get_color black)"\"," >> $nvim_theme
    echo "    red = \"#"(get_color red)"\"," >> $nvim_theme
    echo "    green = \"#"(get_color green)"\"," >> $nvim_theme
