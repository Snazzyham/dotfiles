    echo "set -g fish_color_cwd \"#"(get_color light)"\"" >> $fish_theme
    echo "set -g fish_color_user \"#"(get_color fg)"\"" >> $fish_theme
    echo "set -g fish_color_autosuggestion \"#"(get_color medium)"\"" >> $fish_theme
    echo "set -g fish_color_param \"#"(get_color fg)"\"" >> $fish_theme
    echo "set -g fish_color_option \"#"(get_color fg)"\"" >> $fish_theme
    echo "set -g fish_pager_color_completion \"#"(get_color fg)"\"" >> $fish_theme
