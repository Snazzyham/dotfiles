# Update Fuzzel launcher
function apply_fuzzel
    set -l fuzzel_config "$HOME/.config/fuzzel/fuzzel.ini"

    if not test -f $fuzzel_config
        log_warn "Fuzzel config not found, skipping"
        return
    end

    log_info "Applying to Fuzzel..."

    # Update colors section
    sed -i "/^\[colors\]/,/^\[/ {
        s/^background = .*/background = "(get_color bg)"ee/
        s/^text = .*/text = "(get_color fg)"ff/
        s/^match = .*/match = "(get_color light)"ff/
        s/^selection = .*/selection = "(get_color dark)"ff/
        s/^selection-text = .*/selection-text = "(get_color light)"ff/
        s/^border = .*/border = "(get_color medium)"ff/
        s/^separator = .*/separator = "(get_color dark)"ff/
    }" $fuzzel_config

    log_success "Fuzzel config updated"
end

# Update Rofi - creates a gruvbox-style theme with our colors
function apply_rofi
    set -l rofi_dir "$HOME/.config/rofi"
    set -l themes_dir "$rofi_dir/themes"
    set -l current_theme "$themes_dir/current.rasi"

    if not test -d $rofi_dir
        log_warn "Rofi config not found, skipping"
        return
    end

    log_info "Applying to Rofi..."
    mkdir -p $themes_dir

    # Create a full theme file (gruvbox-style structure with our colors)
    echo '/* Theme: '$THEME_NAME' - Auto-generated by theme-apply.fish
   Based on gruvbox-dark-hard structure */

* {
    highlight: bold italic;
    scrollbar: true;

    /* Theme colors */
    theme-bg0:      #'(get_color bg)';
    theme-bg1:      #'(get_color dark)';
    theme-bg2:      #'(get_color medium)';
    theme-fg0:      #'(get_color fg)';
    theme-fg1:      #'(get_color fg)';
    theme-accent:   #'(get_color light)';
    theme-error:    #'(get_color error)';
    theme-warning:  #'(get_color warning)';
    theme-gray:     #'(get_color medium)';

    /* Applied colors */
    background:                  @theme-bg0;
    background-color:            @background;
    foreground:                  @theme-fg1;
    border-color:                @theme-gray;
    separatorcolor:              @border-color;
    scrollbar-handle:            @border-color;

    normal-background:           @background;
    normal-foreground:           @foreground;
    alternate-normal-background: @background;
    alternate-normal-foreground: @foreground;
    selected-normal-background:  @theme-bg2;
    selected-normal-foreground:  @theme-fg0;

    active-background:           @theme-accent;
    active-foreground:           @background;
    alternate-active-background: @active-background;
    alternate-active-foreground: @active-foreground;
    selected-active-background:  @theme-warning;
    selected-active-foreground:  @active-foreground;

    urgent-background:           @theme-error;
    urgent-foreground:           @background;
    alternate-urgent-background: @urgent-background;
    alternate-urgent-foreground: @urgent-foreground;
    selected-urgent-background:  @theme-error;
    selected-urgent-foreground:  @urgent-foreground;
}

@import "gruvbox-common"' > $current_theme

    log_success "Rofi theme: $current_theme"

    # Update config.rasi to use our theme
    set -l config_file "$rofi_dir/config.rasi"
    if test -f $config_file
        # Replace any @theme line with our theme
        sed -i 's|^@theme .*|@theme "~/.config/rofi/themes/current.rasi"|' $config_file
        sed -i 's|^//@theme|// @theme|' $config_file
        log_success "Updated config.rasi to use current theme"
    end
end

# Update Tmux - creates a current.tmux theme file
function apply_tmux
    set -l tmux_theme "$HOME/.tmux/themes/current.tmux"

    log_info "Applying to Tmux..."

    mkdir -p (dirname $tmux_theme)

    echo "# Theme: $THEME_NAME - Auto-generated by theme-apply.fish" > $tmux_theme
    echo "" >> $tmux_theme
    echo "# Colors:" >> $tmux_theme
    echo "#   bg:      #"(get_color bg) >> $tmux_theme
    echo "#   fg:      #"(get_color fg) >> $tmux_theme
    echo "#   dark:    #"(get_color dark) >> $tmux_theme
    echo "#   medium:  #"(get_color medium) >> $tmux_theme
    echo "#   light:   #"(get_color light) >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Status bar" >> $tmux_theme
    echo "set -g status-style bg=default" >> $tmux_theme
    echo "set -g status-style fg='#"(get_color fg)"'" >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Window status" >> $tmux_theme
    echo "setw -g window-status-current-style 'fg=#"(get_color light)",bg=#"(get_color dark)"'" >> $tmux_theme
    echo "setw -g window-status-style 'fg=#"(get_color medium)",bg=default'" >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Pane borders" >> $tmux_theme
    echo "set -g pane-border-style 'fg=#"(get_color dark)"'" >> $tmux_theme
    echo "set -g pane-active-border-style 'fg=#"(get_color light)"'" >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Window background" >> $tmux_theme
    echo "setw -g window-style 'bg=#"(get_color dark)"'" >> $tmux_theme
    echo "setw -g window-active-style 'bg=#"(get_color bg)"'" >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Message/command style" >> $tmux_theme
    echo "set -g message-style 'fg=#"(get_color bg)",bg=#"(get_color light)"'" >> $tmux_theme
    echo "set -g message-command-style 'fg=#"(get_color bg)",bg=#"(get_color light)"'" >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Mode style (copy mode, etc)" >> $tmux_theme
    echo "set -g mode-style 'fg=#"(get_color bg)",bg=#"(get_color light)"'" >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Clock" >> $tmux_theme
    echo "set -g clock-mode-colour '#"(get_color light)"'" >> $tmux_theme
    echo "set -g clock-mode-style 24" >> $tmux_theme
    echo "" >> $tmux_theme
    echo "# Status bar content" >> $tmux_theme
    echo "set -g status-right '#[fg=#"(get_color light)",bg=#"(get_color dark)"] %H:%M #[fg=#"(get_color medium)"] %y.%m.%d '" >> $tmux_theme
    echo "set-window-option -g window-status-format '#[fg=#"(get_color medium)",bg=default] #I #[fg=#"(get_color medium)",bg=#"(get_color dark)"] #W '" >> $tmux_theme
    echo "set-window-option -g window-status-current-format '#[fg=#"(get_color light)",bg=#"(get_color dark)"] #I #[fg=#"(get_color fg)",bg=#"(get_color dark)"] #W '" >> $tmux_theme

    log_success "Tmux theme: $tmux_theme"

    # Update .tmux.conf to source current theme if it doesn't already
    set -l tmux_conf "$HOME/.tmux.conf"
    if test -f $tmux_conf
        if not grep -q 'current.tmux' $tmux_conf
            log_warn "Add to ~/.tmux.conf: source-file \"\$HOME/.tmux/themes/current.tmux\""
        else
            log_success "Tmux config already sources current.tmux"
        end
    end

    # Reload tmux if running
    if test -n "$TMUX"
        tmux source-file $tmux_conf 2>/dev/null
        log_success "Tmux reloaded"
    end
end

# Update GTK colors (gtk-3.0 and gtk-4.0)
function apply_gtk
    log_info "Applying to GTK..."

    for gtk_ver in 3.0 4.0
        set -l colors_file "$HOME/.config/gtk-$gtk_ver/colors.css"

        if not test -f $colors_file
            log_warn "GTK $gtk_ver colors.css not found, skipping"
            continue
        end

        # Update colors in Breeze-style format
        sed -i 's/@define-color borders_breeze #[0-9a-fA-F]\{6\}/@define-color borders_breeze #'(get_color dark)'/' $colors_file
        sed -i 's/@define-color content_view_bg_breeze #[0-9a-fA-F]\{6\}/@define-color content_view_bg_breeze #'(get_color bg)'/' $colors_file
