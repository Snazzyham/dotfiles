# LS_COLORS for Dark-Violet
set -x LS_COLORS "di=38;5;93:fi=38;5;231:ln=38;5;135:so=38;5;129:pi=38;5;133:ex=38;5;231"

# Fish shell prompt colors based on Base16 Dark‑Violet
set fish_color_normal "#D0D0FA"          # Foreground
set fish_color_command "#8A4CCC"         # Commands
set fish_color_comment "#4C3D73"         # Comments
set fish_color_keyword "#8A4CCC"         # Keywords (if, else)
set fish_color_quote "#B39CDA"           # Quotes
set fish_color_redirection "#4C3D73"     # Redirection symbols
set fish_color_end "#8A4CCC"             # End of statement (;)
set fish_color_error "#D3869B"           # Errors
set fish_color_selection "#2E1F47"       # Selected text background
set fish_color_search_match "#B39CDA"    # Search matches
set fish_color_history_current "#D0D0FA" # Current command in history
set fish_color_operator "#8A4CCC"        # Operators (&&, ||)
set fish_color_escape "#B39CDA"          # Escape sequences
set fish_color_cwd "#B39CDA"             # Current directory in prompt
set fish_color_user "#D0D0FA"            # Username in prompt

# Cursor color for Fish
set fish_cursor_color "#D0D0FA"
