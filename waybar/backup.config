{
    "layer": "top",
    "position": "top",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-right": ["custom/docker", "custom/bluetooth", "tray", "pulseaudio","cpu", "memory", "clock"],
    "hyprland/window": {
        "max-length": 200,
        "separate-outputs": true
    },
  "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "format": "{icon}",
        "format-icons": {
            "active": "󰝥",        /* Filled circle */
            "occupied": "󰪥",      /* Partially filled circle */
            "empty": "󰝦",         /* Empty circle */
            "urgent": "󰊠",
            "default": "󰝦"
        },
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "clock": {
        "format": "󱑃  {:%a %d. %b  %H:%M}"
    },
    "pulseaudio": {
        "format": "󰕾  {volume}",
        "on-click": "pavucontrol"
    },
    "cpu": {
      "format": "󰻠  {usage}% {avg_frequency} ghz"
    },
    "memory": {
      "format": "󰍛  {percentage}%"
    },
    "tray": {
      "icon_size": 16,
      "spacing": 8
    },
    "custom/bluetooth": {
      "exec": "~/.config/waybar/scripts/bt.sh",
      "interval": 5,
      "on-click": "blueman-manager"
    },
    "custom/docker": {
      "exec": "~/.config/waybar/scripts/docker.sh",
      "return-type": "json",
      "interval": 30
    }
}
