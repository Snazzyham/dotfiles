{
    "layer": "top",
    "position": "top",
    "modules-left": ["hyprland/window"],
    "modules-right": ["tray", "custom/lock", "custom/caffeine", "pulseaudio","cpu", "memory", "clock", "hyprland/workspaces"],
    "hyprland/window": {
        "max-length": 200,
        "separate-outputs": true
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "on-click": "activate"
    },
    "clock": {
        "format": "󱑃  {:%a %d. %b  %H:%M}"
    },
    "pulseaudio": {
        "format": "󰕾  {volume}",
        "on-click": "pavucontrol"
    },
    "cpu": {
      "format": "󰻠  {usage}% {avg_frequency} ghz"
    },
    "memory": {
      "format": "󰍛  {percentage}%"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "wlogout",
        "format": "󰤆 "
    },
    "custom/caffeine": {
        "exec": "~/check_swayidle.sh",
        "interval": 20,
        "format": "{}"
    }
}
