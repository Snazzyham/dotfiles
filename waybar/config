{
    "layer": "top",
    "position": "top",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-right": ["custom/warp", "custom/docker", "custom/bluetooth", "tray", "pulseaudio", "custom/brightness", "network", "cpu", "memory", "battery", "clock"],

    "hyprland/window": {
        "max-length": 100,
        "separate-outputs": true
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "format": "{icon}",
        "format-icons": {
            "active": "",
            "occupied": "",
            "empty": "",
            "urgent": "󰀦",
            "default": ""
        },
        "persistent_workspaces": {
            "1": [], "2": [], "3": [], "4": [], "5": []
        }
    },

    "clock": {
        "format": "󰥔  {:%a %d %b • %H:%M}"
    },

    "pulseaudio": {
        "format": "󰕾 {volume}%",
        "on-click": "pavucontrol"
    },

    "cpu": {
        "format": "󰻠 {usage}%"
    },

    "memory": {
        "format": "󰍛 {percentage}%"
    },

    "tray": {
        "icon_size": 18,
        "spacing": 12
    },

    "custom/bluetooth": {
        "exec": "~/.config/waybar/scripts/bt.sh",
        "interval": 5,
        "on-click": "blueman-manager"
    },

    "custom/docker": {
        "exec": "~/.config/waybar/scripts/docker.sh",
        "return-type": "json",
        "interval": 30
    },
    "custom/brightness": {
	"exec": "~/.config/waybar/scripts/brightness.sh",
	"interval": 5,
	"format": "{}%"
    },
    "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄 {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": ["󰂎", "󰂑", "󰂔", "󰂗", "󰁿"],
    "states": {
        "good": 90,
        "warning": 30,
        "critical": 15
    },
    "tooltip": true,
    "interval": 10
    },
    "network": {
        "interface": "wlan0",
        "format-wifi": "󰤨  {essid}",
        "format-ethernet": "󰈀 {ifname}",
        "format-disconnected": "󰤮 Disconnected",
        "tooltip": true,
        "tooltip-format": "{ifname} via {gwaddr}",
        "on-click-right": "nm-connection-editor",
        "on-click": "~/.config/waybar/scripts/wifi_details.sh"
    },
    "custom/warp": {
      "exec": "~/.config/waybar/scripts/warp_status.sh",
      "return-type": "json",
      "interval": 5,
      "on-click": "~/.config/waybar/scripts/warp_toggle.sh"
    }
}
