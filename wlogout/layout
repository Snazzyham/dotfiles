{
    "label" : "lock",
    "action" : "killall Discord || true && swaylock -f && sleep 1 && hyprctl dispatch dpms off",
    "text" : "Lock",
    "keybind" : "l"
}

{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Logout",
    "keybind" : "e"
}

{
    "label" : "suspend",
    "action" : "swaylock -f && systemctl suspend",
    "text" : "Suspend",
    "keybind" : "s"
}

{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "o"
}

{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}

{
  "label": "fix-audio",
  "action": "hyprctl dispatch dpms off && hyprctl dispatch dpms on",
  "text": "Fix Audio",
  "keybind": "a"
}
